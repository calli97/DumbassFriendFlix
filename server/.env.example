# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=dumbassfriendflix

# Storage — absolute path to the directory where uploaded videos will be saved
# The directory MUST exist before starting the server
STORE_PATH=/absolute/path/to/storage

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
