# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=dumbassfriendflix

# Storage — absolute path to the directory where uploaded videos will be saved
# The directory MUST exist before starting the server
STORE_PATH=/absolute/path/to/storage

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# MinIO object storage (required only when uploading with storageType=minio)
# MINIO_HOST must include the protocol (http:// or https://)
MINIO_USER=your-minio-access-key
MINIO_PASSWORD=your-minio-secret-key
MINIO_HOST=http://your-minio-host
MINIO_PORT=9000
MINIO_BUCKET=your-bucket-name
